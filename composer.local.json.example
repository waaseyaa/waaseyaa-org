{
    "_comment": "Per-developer overrides. Copy to composer.local.json (gitignored). wikimedia/composer-merge-plugin merges this file; prepend-repositories makes local path repos win over Packagist.",
    "repositories": [
        {
            "type": "path",
            "url": "../waaseyaa/packages/*",
            "options": {
                "symlink": true
            }
        }
    ]
}
