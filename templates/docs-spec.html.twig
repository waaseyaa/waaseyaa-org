{% extends "base.html.twig" %}

{% block title %}{{ title }}: Waaseyaa spec{% endblock %}
{% block description %}Waaseyaa framework spec {{ name }}.md, framework {{ framework_version|default('unknown') }}. Also available as Markdown and over MCP.{% endblock %}

{% block nav %}
  <a href="/docs" aria-current="page">Docs</a>
  <a href="/why">Why Waaseyaa</a>
  <a href="/compare">Compare</a>
  <a href="https://github.com/waaseyaa/framework">GitHub</a>
{% endblock %}

{% block head %}
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="alternate" type="text/markdown" href="{{ markdown_url }}">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": {{ title|json_encode|raw }},
    "url": {{ canonical_url|json_encode|raw }},
    "version": {{ framework_version|default('unknown')|json_encode|raw }},
    "about": "Waaseyaa framework specification",
    "isPartOf": { "@type": "WebSite", "name": "Waaseyaa", "url": "/" },
    "license": "https://spdx.org/licenses/GPL-2.0-or-later.html"
  }
  </script>
{% endblock %}

{% block content %}
<main class="page page-spec">
  <div class="crumb">
    <span><a href="/docs">docs</a> / specs / {{ name }}.md</span>
    <div class="raw">
      <span class="on">HTML</span>
      <a href="{{ markdown_url }}">Markdown</a>
      <a href="/.well-known/mcp.json" title="Read-only MCP endpoint at /mcp">MCP</a>
    </div>
  </div>
  <p class="provenance">framework {{ framework_version|default('unknown') }} &middot; synced verbatim from the framework's docs/specs corpus</p>
  <article class="spec-body">
    {{ body|raw }}
  </article>
</main>
{% endblock %}
