{% extends "base.html.twig" %}

{% block title %}Waaseyaa: sovereign content platforms, readable by humans and agents alike{% endblock %}

{% block head %}
<link rel="stylesheet" href="/workspace/assets/workspace-chat.css">
<style>
  /* Theme the shared chat surface with the site tokens. */
  [data-ws-chat] {
    --ws-accent: #0f766e;
    --ws-accent-strong: #0d4f4f;
    --ws-accent-soft: #e4f4f1;
    --ws-ink: #0c1f1d;
    --ws-muted: #46615d;
    --ws-line: #d4e6e2;
    --ws-bg: #f4faf8;
    --ws-user-bubble: #07211e;
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }
</style>
{% endblock %}

{% block content %}
<main>

  <section class="hero">
    <h1>Sovereign content platforms,<br><em>readable by humans and agents alike.</em></h1>
    <p class="lede">Spec-driven inside, agent-readable outside. One docs corpus, three renderings: HTML pages, clean Markdown at the same URLs, and an MCP server your agent can call.</p>
    <p class="stage">{{ framework_version|default('alpha') }} &middot; alpha &middot; in production at First Nations Procurement Inc.</p>
  </section>

  <section class="installs">
    <div class="card">
      <h3>For you</h3>
      <div class="cmd">$ composer create-project waaseyaa/waaseyaa my-app --stability=dev</div>
      <p>PHP 8.5, SQLite by default, one process. Runs in production on a Raspberry Pi.</p>
    </div>
    <div class="card">
      <h3>For your AI client</h3>
      <div class="cmd">$ vendor/bin/waaseyaa bimaaji:install</div>
      <p>Framework guidelines and skills for Claude Code, Cursor, Copilot, Codex, Gemini, Windsurf, and Junie, installed from the framework itself.</p>
    </div>
  </section>

  <section class="proof">
    <div>7 enforced layers</div>
    <div>Spec-driven, natively</div>
    <div>OCAP audit log in core</div>
    <div>CI-gated conventions</div>
    <div>Production on a Raspberry Pi</div>
  </section>

  <section class="surface">
    <div class="chat">
      <div class="chat-h">Ask the docs &middot; answers cite the specs</div>
      {% include 'workspace/chat-panel.html.twig' with { chat: {
        title: 'Docs assistant',
        subtitle: 'Grounded on the spec corpus',
        avatar: 'W',
        placeholder: 'Ask about the framework...',
        intro: 'I answer from the framework spec corpus and cite the spec behind every answer. The same corpus is on /docs, as Markdown, and over MCP.',
        chips: ['How do I add an entity type?', 'What is Bimaaji?', 'How does the OCAP audit log work?'],
      } } only %}
    </div>
    <div class="doc" id="doc">
      <div class="crumb"><span><a href="/docs/specs/entity-system">docs / specs / entity-system.md</a></span>
        <div class="raw" data-toggle hidden><button type="button" class="on" data-view="html">HTML</button><button type="button" data-view="md">Markdown</button></div>
      </div>
      <div class="htmlview">
        <h1>Entity system</h1>
        <p class="lede">Every piece of content is a typed, revisionable, access-controlled entity. The docs pages on this site are served from the same spec corpus your agent can query.</p>
        <div class="code">
<span class="k">new</span> <span class="t">EntityType</span>(<br>
&nbsp;&nbsp;id: <span class="s">'story'</span>,<br>
&nbsp;&nbsp;label: <span class="s">'Story'</span>,<br>
&nbsp;&nbsp;class: <span class="t">Story</span>::class,<br>
&nbsp;&nbsp;storageClass: <span class="t">SqlEntityStorage</span>::class,<br>
&nbsp;&nbsp;keys: [<span class="s">'id'</span> =&gt; <span class="s">'id'</span>, <span class="s">'label'</span> =&gt; <span class="s">'title'</span>],<br>
&nbsp;&nbsp;revisionable: <span class="k">true</span>,<br>
);</div>
        <h2>Two-axis storage</h2>
        <p>Revisionable and translatable are independent axes, resolved at schema time. The same pipeline serves this website and a Nation's member portal.</p>
      </div>
      <div class="md"># Entity system

Every piece of content is a typed, revisionable, access-controlled
entity. The docs pages on this site are served from the same spec
corpus your agent can query.

```php
new EntityType(
    id: 'story',
    label: 'Story',
    class: Story::class,
    storageClass: SqlEntityStorage::class,
    keys: ['id' => 'id', 'label' => 'title'],
    revisionable: true,
);
```

## Two-axis storage

Revisionable and translatable are independent axes, resolved at
schema time.</div>
    </div>
  </section>

</main>
{% endblock %}

{% block scripts %}
<script src="/workspace/assets/workspace-md.js"></script>
<script src="/workspace/assets/workspace-chat.js"></script>
<script>
(function () {
  var doc = document.getElementById('doc');
  var bar = doc ? doc.querySelector('[data-toggle]') : null;
  if (bar) {
    bar.hidden = false;
    bar.addEventListener('click', function (e) {
      var btn = e.target.closest('button[data-view]');
      if (!btn) return;
      doc.classList.toggle('rawmode', btn.dataset.view === 'md');
      bar.querySelectorAll('button').forEach(function (b) {
        b.classList.toggle('on', b === btn);
      });
    });
  }

  if (window.WaaseyaaChat) {
    WaaseyaaChat.mount(document.querySelector('[data-ws-chat]'), {
      endpoints: {
        send: '/docs-chat/send',
        apply: '/docs-chat/send',
        messages: function (id) { return '/docs-chat/' + id + '/messages'; }
      },
      thread: { key: 'ws.chat.docs.pub', initial: 0 },
      user: { id: 0, label: 'You' },
      limit: 500,
      chips: ['How do I add an entity type?', 'What is Bimaaji?', 'How does the OCAP audit log work?'],
      avatars: { user: 'YOU', ai: 'W' }
    });
  }
})();
</script>
{% endblock %}
